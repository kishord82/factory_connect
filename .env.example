# FactoryConnect Environment Variables
# Copy to .env and fill in values. NEVER commit .env

# Database
DATABASE_URL=postgres://fc_app:fc_password@localhost:5432/factoryconnect?sslmode=disable
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=factoryconnect
DATABASE_USER=fc_app
DATABASE_PASSWORD=fc_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=factoryconnect
KEYCLOAK_CLIENT_ID=fc-api
KEYCLOAK_CLIENT_SECRET=change-me

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=fc-dev-token

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=fc-minio-access
MINIO_SECRET_KEY=fc-minio-secret
MINIO_BUCKET=factoryconnect

# OpenAS2
OPENAS2_HTTP_PORT=4080
OPENAS2_HTTPS_PORT=4081

# API
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Portal
PORTAL_PORT=5173

# Claude API (for AI Mapping)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# Feature Flags
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
