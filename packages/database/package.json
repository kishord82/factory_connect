{
  "name": "@fc/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "dbmate up",
    "migrate:down": "dbmate rollback",
    "migrate:reset": "dbmate drop && dbmate up",
    "migrate:new": "dbmate new"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "@fc/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-sonarjs": "^0.25.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
