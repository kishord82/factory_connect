{
  "name": "@fc/observability",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js",
      "default": "./dist/logger.js"
    },
    "./pii-redactor": {
      "types": "./dist/pii-redactor.d.ts",
      "import": "./dist/pii-redactor.js",
      "default": "./dist/pii-redactor.js"
    },
    "./http-logger": {
      "types": "./dist/http-logger.d.ts",
      "import": "./dist/http-logger.js",
      "default": "./dist/http-logger.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "@fc/shared": "workspace:*"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-sonarjs": "^0.25.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
