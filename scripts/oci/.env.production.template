###############################################################################
# FactoryConnect — OCI Production Environment Template
# Copy to .env.production and fill in ALL values
#
#   cp .env.production.template .env.production
#   nano .env.production   # replace every CHANGE_ME
#
# NEVER commit .env.production — it is gitignored.
# Rotate all passwords after first successful deployment.
###############################################################################

# ─── Domain / Hostname ────────────────────────────────────────────────────────
# Set to your OCI public IP or a real domain (e.g. demo.factoryconnect.in)
# Caddy auto-provisions a Let's Encrypt cert when this is a real domain.
# For IP-only access, Caddy serves plain HTTP.
DOMAIN=CHANGE_ME

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=factoryconnect
POSTGRES_USER=fc_app
POSTGRES_PASSWORD=CHANGE_ME

# Constructed from the values above — update if you change user/password/host
DATABASE_URL=postgresql://fc_app:CHANGE_ME@postgres:5432/factoryconnect

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ─── Keycloak (Auth + MFA) ────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=factoryconnect
KEYCLOAK_CLIENT_ID=fc-api
# Fill in after creating the client in Keycloak admin console
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# ─── HashiCorp Vault ──────────────────────────────────────────────────────────
# Dev-mode Vault is fine for demos. Use a managed Vault for real production.
VAULT_DEV_ROOT_TOKEN_ID=CHANGE_ME
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME   # same value as VAULT_DEV_ROOT_TOKEN_ID

# ─── MinIO (S3-compatible Object Storage) ─────────────────────────────────────
MINIO_ROOT_USER=fc-minio-admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=fc-minio-admin   # same as MINIO_ROOT_USER
MINIO_SECRET_KEY=CHANGE_ME        # same as MINIO_ROOT_PASSWORD

# ─── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
ENABLE_WEBSOCKET=true

# ─── Let's Encrypt (auto-SSL via Caddy) ───────────────────────────────────────
# Only required when DOMAIN is a real hostname, not an IP
ACME_EMAIL=admin@factoryconnect.in
