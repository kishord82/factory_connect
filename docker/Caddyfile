###############################################################################
# FactoryConnect — Caddy Reverse Proxy Configuration
# Auto-SSL via Let's Encrypt, routing, compression, security headers
###############################################################################

# Global configuration
{
  # Email for Let's Encrypt notifications
  email {$ACME_EMAIL:-admin@factoryconnect.in}

  # ACME server configuration
  acme_ca {$ACME_CA:-https://acme-v02.api.letsencrypt.org/directory}
}

# Production domain with auto-SSL
(factoryconnect.in) {
  # Security headers — apply to all routes
  header {
    # HSTS: enforce HTTPS for 1 year
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Prevent clickjacking
    X-Frame-Options "SAMEORIGIN"

    # Prevent MIME type sniffing
    X-Content-Type-Options "nosniff"

    # XSS Protection
    X-XSS-Protection "1; mode=block"

    # Referrer policy
    Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy (formerly Feature-Policy)
    Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Remove Caddy version header
    -Server
  }

  # Compression
  encode gzip {
    match {
      header Content-Type text/*
      header Content-Type application/json
      header Content-Type application/javascript
      header Content-Type application/xml
    }
    minimum_length 1024
  }

  # Access logging
  log {
    output file /var/log/caddy/access.log {
      roll_size 100MB
      roll_keep 10
    }
    format json {
      time_format iso8601
    }
  }
}

# Localhost development fallback (when domain not available)
:80 {
  header {
    X-Frame-Options "SAMEORIGIN"
    X-Content-Type-Options "nosniff"
  }

  encode gzip

  # API routes → api:3000 with load balancing
  handle /api/* {
    reverse_proxy api-1:3000 api-2:3000 {
      policy round_robin
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
      header_up X-Forwarded-Host {http.request.host}

      # Preserve correlation ID
      header_up X-Correlation-ID {http.request.header.X-Correlation-ID}

      # Health check configuration
      health_uri /health
      health_interval 10s
      health_timeout 5s
    }
  }

  # WebSocket routes → api:3000
  handle /ws/* {
    reverse_proxy api-1:3000 api-2:3000 {
      policy round_robin
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
      header_up X-Forwarded-Host {http.request.host}
      header_up Connection "Upgrade"
      header_up Upgrade "websocket"

      # WebSocket timeout
      transport http {
        dial_timeout 10s
        read_timeout 300s
        write_timeout 300s
      }
    }
  }

  # Health check endpoint (internal)
  handle /health {
    respond "healthy" 200
  }

  # Metrics endpoint — prometheus only
  handle /metrics {
    @metrics {
      remote_ip 127.0.0.1 172.28.0.0/16
    }
    reverse_proxy @metrics prometheus:9090 {
      header_up Authorization "Bearer {$PROMETHEUS_AUTH_TOKEN}"
    }
    respond @metrics 403
  }

  # Admin endpoints — restricted to internal network
  handle /admin/* {
    @admin_access {
      remote_ip 127.0.0.1 172.28.0.0/16
    }
    reverse_proxy @admin_access api-1:3000 {
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
    respond @admin_access 403
  }

  # Portal routes → portal:3001
  handle * {
    reverse_proxy portal:3001 {
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
      header_up X-Forwarded-Host {http.request.host}
    }
  }
}

# Hostname-based routing with auto-SSL (when domain is available)
factoryconnect.in:443, www.factoryconnect.in:443 {
  import factoryconnect.in

  # API routes with rate limiting
  handle /api/* {
    rate_limit {
      zone api_zone {
        key {http.request.remote}
        rate 1000/m
      }
    }

    reverse_proxy api-1:3000 api-2:3000 {
      policy round_robin
      health_uri /health
      health_interval 10s
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Host {http.request.host}
      header_up X-Correlation-ID {http.request.header.X-Correlation-ID}
    }
  }

  # WebSocket routes
  handle /ws/* {
    reverse_proxy api-1:3000 api-2:3000 {
      policy round_robin
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Host {http.request.host}
      header_up Connection "Upgrade"
      header_up Upgrade "websocket"
      transport http {
        read_timeout 300s
        write_timeout 300s
      }
    }
  }

  # Health endpoint
  handle /health {
    respond "healthy" 200
  }

  # Metrics — internal only
  handle /metrics {
    @metrics {
      remote_ip 127.0.0.1 172.28.0.0/16
    }
    reverse_proxy @metrics prometheus:9090
    respond @metrics 403
  }

  # Admin — internal only
  handle /admin/* {
    @admin {
      remote_ip 127.0.0.1 172.28.0.0/16
    }
    reverse_proxy @admin api-1:3000
    respond @admin 403
  }

  # Portal SPA
  handle * {
    reverse_proxy portal:3001 {
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Host {http.request.host}
    }
  }
}

# HTTPS redirect (auto-SSL)
http:// {
  redir https://{http.request.host}{http.request.uri} permanent
}
