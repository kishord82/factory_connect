###############################################################################
# FactoryConnect — Production Environment Template
# Copy to .env.production and fill in actual values
# NEVER commit .env.production to version control
###############################################################################

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_NAME=factoryconnect
DATABASE_USER=fc_app
DATABASE_PASSWORD=<STRONG_PASSWORD_HERE>
DATABASE_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=<STRONG_PASSWORD_HERE>
REDIS_MAX_MEMORY=512mb

# ─── Keycloak (Auth + MFA) ────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<STRONG_PASSWORD_HERE>
KEYCLOAK_REALM=factoryconnect
KEYCLOAK_CLIENT_ID=fc-api
KEYCLOAK_CLIENT_SECRET=<JWT_CLIENT_SECRET_FROM_KEYCLOAK>

# ─── HashiCorp Vault ──────────────────────────────────────────────────
# In production, migrate to managed Vault instance
VAULT_DEV_ROOT_TOKEN_ID=<VAULT_ROOT_TOKEN>
VAULT_ADDR=http://vault:8200

# ─── MinIO (S3-compatible Object Storage) ─────────────────────────────
# For claim check payloads and file uploads
MINIO_ROOT_USER=fc-minio-user
MINIO_ROOT_PASSWORD=<STRONG_MINIO_PASSWORD>

# ─── API Configuration ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Correlation ID tracking header
CORRELATION_ID_HEADER=X-Correlation-ID

# ─── TLS / HTTPS ──────────────────────────────────────────────────────
# Let's Encrypt ACME email
ACME_EMAIL=admin@factoryconnect.in

# ACME CA (production use Let's Encrypt directory)
ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# ─── Prometheus + Grafana ─────────────────────────────────────────────
PROMETHEUS_AUTH_TOKEN=<OPTIONAL_AUTH_TOKEN>

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<STRONG_GRAFANA_PASSWORD>
GRAFANA_ROOT_URL=https://grafana.factoryconnect.in

# ─── Service Timeouts (milliseconds) ──────────────────────────────────
DB_CONNECTION_TIMEOUT=10000
REDIS_CONNECTION_TIMEOUT=5000
HTTP_REQUEST_TIMEOUT=30000

# ─── BullMQ Worker Configuration ──────────────────────────────────────
# Max job concurrency per worker
BULL_CONCURRENCY=10

# Job timeout (ms)
BULL_JOB_TIMEOUT=300000

# Attempts before job fails
BULL_MAX_ATTEMPTS=3

# ─── File Upload Configuration ────────────────────────────────────────
# Max claim check payload size (bytes)
CLAIM_CHECK_THRESHOLD=262144

# MinIO bucket names
MINIO_BUCKET_ORDERS=fc-orders
MINIO_BUCKET_INVOICES=fc-invoices
MINIO_BUCKET_DOCUMENTS=fc-documents
MINIO_BUCKET_ATTACHMENTS=fc-attachments

# ─── Outbox Poller Configuration ──────────────────────────────────────
# Poll interval (ms)
OUTBOX_POLL_INTERVAL=5000

# Max batch size
OUTBOX_BATCH_SIZE=100

# ─── Saga Configuration ───────────────────────────────────────────────
# Saga state machine deadline (ms)
SAGA_DEFAULT_DEADLINE=86400000

# Retry delay (exponential backoff base)
SAGA_RETRY_DELAY_BASE=1000

# ─── Circuit Breaker Configuration ───────────────────────────────────
# For cross-service calls (Opossum)

# Number of failing requests before opening circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Time window to measure failures (ms)
CIRCUIT_BREAKER_FAILURE_WINDOW=60000

# Time to wait before attempting recovery (ms)
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# ─── Security Configuration ───────────────────────────────────────────
# CORS allowed origins
CORS_ORIGIN=https://factoryconnect.in,https://www.factoryconnect.in

# Rate limiting: requests per minute
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# ─── Audit & Compliance ───────────────────────────────────────────────
# Enable full audit logging
AUDIT_LOG_ENABLED=true

# Enable PII redaction in logs
PII_REDACTION_ENABLED=true

# ─── Optional: Service Integrations ────────────────────────────────────
# Email service (for notifications)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@factoryconnect.in
SMTP_PASSWORD=<EMAIL_PASSWORD>
SMTP_FROM=FactoryConnect <noreply@factoryconnect.in>

# SMS service (for OTP, notifications)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=<TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<TWILIO_AUTH_TOKEN>
TWILIO_FROM_NUMBER=<YOUR_TWILIO_PHONE>

# ─── Monitoring & Observability ───────────────────────────────────────
# Enable Prometheus metrics
METRICS_ENABLED=true

# Enable Jaeger distributed tracing (if available)
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# ─── Feature Flags ────────────────────────────────────────────────────
# Feature flags are stored in database (platform.feature_flags table)
# Set default feature flag values here (can be overridden per tenant)

FEATURE_FLAG_SANDBOX_TEST_HARNESS=false
FEATURE_FLAG_EDI_AS2_BRIDGE=true
FEATURE_FLAG_MAPPING_STUDIO=true
FEATURE_FLAG_AI_MAPPER=true
FEATURE_FLAG_LLM_AUTO_FIX=false

# ─── Development / Debug (DO NOT ENABLE IN PRODUCTION) ──────────────
# Debug mode (verbose logging)
DEBUG=false

# Allow health check without auth
HEALTH_CHECK_REQUIRES_AUTH=false

# Pretty print JSON responses
PRETTY_JSON=false
