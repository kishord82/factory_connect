{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@fc/shared": ["../../packages/shared/dist/index.js"],
      "@fc/database": ["../../packages/database/dist/index.js"],
      "@fc/observability": ["../../packages/observability/dist/index.js"]
    },
    "skipLibCheck": true,
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts"]
}
